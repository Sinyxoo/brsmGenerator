<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:id="root"
      fx:controller="by.brsm.app.ui.AgendaItemCardController"
      spacing="8" style="-fx-border-color: #cccccc; -fx-border-radius: 6; -fx-background-color: #fafafa;">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="orderLabel" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="typeCombo" prefWidth="320" promptText="Тип вопроса"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Удалить" onAction="#onRemove" style="-fx-text-fill: #a00000;"/>
    </HBox>

    <GridPane fx:id="dynamicFields" hgap="10" vgap="6"/>

    <HBox spacing="16" alignment="CENTER_LEFT">
        <Label text="Голосов «за» по вопросу:"/>
        <Spinner fx:id="votesSpinner" editable="true" prefWidth="80"/>
        <CheckBox fx:id="resolutionCheckBox" text="Формировать отдельное Постановление"/>
    </HBox>

    <GridPane hgap="10" vgap="6">
        <Label text="Докладчик (СЛУШАЛИ):" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="speakerCombo" prefWidth="280" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Выступивший:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="supporterCombo" prefWidth="280" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>
</VBox>
